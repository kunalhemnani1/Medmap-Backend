// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String               @id @default(uuid())
  name           String
  email          String               @unique
  createdAt      DateTime             @default(now())
  emailVerified  Boolean              @default(false)
  image          String?
  updatedAt      DateTime             @updatedAt
  sessions       Session[]
  accounts       Account[]
  bookmarks      Bookmark[]
  hospitals      RegisteredHospital[]
  appointments   Appointment[]        @relation("PatientAppointments")
  reviews        HospitalReview[]     @relation("UserReviews")
  doctorProfiles HospitalDoctor[]     @relation("DoctorProfile")
  doctorRequests DoctorRequest[]

  role String? @default("user")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospitalId Int
  note       String?
  createdAt  DateTime @default(now())

  @@unique([userId, hospitalId])
  @@index([userId])
  @@map("bookmark")
}

// ── Registered Hospitals (provider-managed) ──────────────────────────────

model RegisteredHospital {
  id                 String           @id @default(uuid())
  ownerId            String
  owner              User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name               String
  registrationNumber String?
  type               String           @default("General")
  address            String
  city               String
  state              String
  pincode            String
  latitude           Float?
  longitude          Float?
  phone              String
  email              String
  website            String?
  description        String?
  isVerified         Boolean          @default(false)
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  doctors            HospitalDoctor[]
  prices             HospitalPrice[]
  appointments       Appointment[]
  reviews            HospitalReview[]
  doctorRequests     DoctorRequest[]

  @@index([ownerId])
  @@index([state, city])
  @@map("registered_hospital")
}

model HospitalDoctor {
  id               String             @id @default(uuid())
  hospitalId       String
  hospital         RegisteredHospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?              @relation("DoctorProfile", fields: [userId], references: [id], onDelete: SetNull)
  name             String
  email            String?
  qualification    String
  specialty        String
  subSpecialty     String?
  experienceYears  Int                @default(0)
  consultationFee  Int                @default(500)
  availableDays    String             @default("Mon,Tue,Wed,Thu,Fri")
  availableFrom    String             @default("09:00")
  availableTo      String             @default("17:00")
  maxSlotsPerDay   Int                @default(20)
  phone            String?
  acceptedByDoctor Boolean            @default(false) // 3-way handshake: admin adds, doctor accepts
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  appointments     Appointment[]

  @@index([hospitalId])
  @@index([userId])
  @@map("hospital_doctor")
}

model HospitalPrice {
  id          String             @id @default(uuid())
  hospitalId  String
  hospital    RegisteredHospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  category    String // e.g. "Surgery", "Consultation", "Diagnostics"
  name        String
  description String?
  priceMin    Int
  priceMax    Int
  currency    String             @default("INR")
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([hospitalId])
  @@map("hospital_price")
}

model Appointment {
  id              String             @id @default(uuid())
  hospitalId      String
  hospital        RegisteredHospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  doctorId        String?
  doctor          HospitalDoctor?    @relation(fields: [doctorId], references: [id])
  patientId       String
  patient         User               @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  patientName     String
  patientPhone    String
  patientEmail    String
  procedure       String
  appointmentDate DateTime
  appointmentTime String
  status          String             @default("pending") // pending | confirmed | cancelled | completed
  notes           String?
  estimatedCost   Int?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([hospitalId])
  @@index([patientId])
  @@index([doctorId])
  @@map("appointment")
}

model HospitalReview {
  id                  String             @id @default(uuid())
  hospitalId          String
  hospital            RegisteredHospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  authorId            String
  author              User               @relation("UserReviews", fields: [authorId], references: [id], onDelete: Cascade)
  authorName          String
  appointmentId       String? // links review to a real visit
  // Multi-category ratings (1-5)
  ratingWaiting       Int                @default(3)
  ratingCommunication Int                @default(3)
  ratingStaff         Int                @default(3)
  ratingCleanliness   Int                @default(3)
  ratingOverall       Int                @default(3)
  rating              Int // legacy / computed average
  title               String?
  comment             String
  visitDate           DateTime?
  phone               String?
  // Verification
  isVerifiedVisit     Boolean            @default(false) // matched to an appointment
  reviewToken         String? // token used for verification
  // Fake detection
  ipAddress           String?
  userAgent           String?
  isFlagged           Boolean            @default(false)
  flagReason          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([hospitalId])
  @@index([authorId])
  @@index([appointmentId])
  @@map("hospital_review")
}

// ── Doctor Registration Requests ────────────────────────────────────────────

model DoctorRequest {
  id            String             @id @default(uuid())
  hospitalId    String
  hospital      RegisteredHospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  requesterId   String
  requester     User               @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  name          String
  email         String
  phone         String?
  qualification String
  specialty     String
  medicalRegNo  String // doctor's ID / registration number
  documentUrl   String? // uploaded identification document
  status        String             @default("pending") // pending | approved | rejected
  adminNotes    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([hospitalId])
  @@index([requesterId])
  @@map("doctor_request")
}

// ── Review Token (generated after appointment completion) ───────────────────

model ReviewToken {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  patientId     String
  hospitalId    String
  token         String   @unique
  used          Boolean  @default(false)
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([token])
  @@index([patientId])
  @@map("review_token")
}
