{
  "name": "MedMap-Backend",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/server.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/server.js",
    "dev": "nodemon",
    "sync:es": "tsx server/scripts/sync-es.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma": "prisma migrage dev && prisma generate",
    "auth:generate": "pnpm dlx auth@latest generate --config ./server/lib/auth.ts",
    "docker:es": "docker run -d -p 9200:9200 -e discovery.type=single-node -e xpack.security.enabled=false elasticsearch:8.17.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@upstash/redis": "^1.36.3",
    "better-auth": "^1.5.4",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongodb": "^7.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "dotenv": "^17.3.1",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.4.2",
    "tsx": "^4.21.0"
  }
}